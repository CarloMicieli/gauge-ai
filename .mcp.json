{
  "mcpServers": {
    "rust-analyzer": {
      "command": "rust-analyzer-mcp",
      "args": [],
      "cwd": ".",
      "env": {
        "LSP_TIMEOUT": "300",
        "RA_LOG": "info",
        "CARGO_TARGET_DIR": "target/mcp-analyzer"
      }
    },
    "rust-mcp-server": {
      "command": "rust-mcp-server",
      "args": ["--workspace", "..", "--log-file", "/home/carlo/.log/rust-mcp-server.log"],
      "cwd": ".",
      "env": {
        "RUST_BACKTRACE": "1"
      }
    },
    "sqlite-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-sqlite-npx",
        "/home/carlo/.local/share/io.github.carlomicieli.rustyshed/database.sqlite"
      ]
    }
  }
}
